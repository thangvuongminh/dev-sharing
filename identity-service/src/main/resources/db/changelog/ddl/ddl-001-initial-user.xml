<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001" author="i_love_my_duong">
        <createTable tableName="user">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="email" type="varchar(255)"><constraints nullable="false" unique="true"/></column>
            <column name="password" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="firstname" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="lastname" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="phone_number" type="varchar(15)"><constraints nullable="false"/></column>
            <column name="status" type="varchar(10)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="002" author="i_love_my_duong">
        <createTable tableName="role">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role_name" type="bigint"><constraints nullable="false"/></column>
            <column name="description" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="003" author="i_love_my_duong">
        <createTable tableName="user_role">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
            <column name="role_id" type="bigint"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="004" author="i_love_my_duong">
        <createTable tableName="user_verification">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="verification_code" type="varchar(50)"><constraints nullable="false"/></column>
            <column name="expired_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="channel" type="varchar(20)"><constraints nullable="false"/></column>
            <column name="verified_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="receiver" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="005" author="i_love_my_duong">
        <createTable tableName="user_profile">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="birthday" type="date"><constraints nullable="false"/></column>
            <column name="gender" type="varchar(10)"><constraints nullable="false"/></column>
            <column name="address" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="bio" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="avatar" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="company" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="year_of_experience" type="tinyint"><constraints nullable="false"/></column>
            <column name="education_level" type="tinyint"><constraints nullable="false"/></column>
            <column name="linkedin" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="facebook" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="personal_website" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
            <column name="user_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="006" author="i_love_my_duong">
        <createTable tableName="user_interest">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="interest_name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="interest_level" type="tinyint"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
            <column name="profile_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="007" author="i_love_my_duong">
        <createTable tableName="user_skill">
            <column name="id" type="bigint unsigned" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="skill_name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="proficiency_level" type="tinyint"><constraints nullable="false"/></column>
            <column name="year_of_experience" type="tinyint"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp"><constraints nullable="false"/></column>
            <column name="created_by" type="bigint"><constraints nullable="false"/></column>
            <column name="updated_by" type="bigint"><constraints nullable="false"/></column>
            <column name="profile_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>


</databaseChangeLog>