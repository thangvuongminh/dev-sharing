<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
  <!--  Create rating table  -->
  <changeSet id="rating-0001-create-rating-table" author="thangVm">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="rating"/>
      </not>
    </preConditions>
    <createTable tableName="rating">
      <column name="id" type="BIGINT UNSIGNED" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="content_id" type="VARCHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="user_id" type="VARCHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="rating_value" type="TINYINT">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addUniqueConstraint tableName="rating" columnNames="content_id,user_id" constraintName="uk_content_user"/>
    <createIndex tableName="rating" indexName="idx_content_id">
      <column name="content_id"/>
    </createIndex>
    <createIndex tableName="rating" indexName="idx_user_id">
      <column name="user_id"/>
    </createIndex>
    <createIndex tableName="rating" indexName="idx_rating_value">
      <column name="rating_value"/>
    </createIndex>
    <sql>
<![CDATA[ ALTER TABLE rating ADD CONSTRAINT chk_rating_value CHECK (rating_value >= 1 AND rating_value <= 5); ]]>
</sql>
  </changeSet>
  <!--  Create review table  -->
  <changeSet id="rating-0002-create-review-table" author="thangVm">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="review"/>
      </not>
    </preConditions>
    <createTable tableName="review">
      <column name="id" type="BIGINT UNSIGNED" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="rating_id" type="BIGINT UNSIGNED">
        <constraints nullable="false"/>
      </column>
      <column name="content_id" type="VARCHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="user_id" type="VARCHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="title" type="VARCHAR(255)"/>
      <column name="content" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
        <constraints nullable="false"/>
      </column>
      <column name="is_verified_purchase" type="BOOLEAN" defaultValueBoolean="false"/>
      <column name="helpful_count" type="INT" defaultValueNumeric="0"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="review" baseColumnNames="rating_id" constraintName="fk_review_rating" referencedTableName="rating" referencedColumnNames="id" onDelete="CASCADE"/>
    <createIndex tableName="review" indexName="idx_review_content_id">
      <column name="content_id"/>
    </createIndex>
    <createIndex tableName="review" indexName="idx_review_user_id">
      <column name="user_id"/>
    </createIndex>
    <createIndex tableName="review" indexName="idx_review_status">
      <column name="status"/>
    </createIndex>
    <createIndex tableName="review" indexName="idx_review_created_at">
      <column name="created_at"/>
    </createIndex>
  </changeSet>
  <!--  Create content_statistics table  -->
  <changeSet id="rating-0003-create-statistics-table" author="thangVm">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="content_statistics"/>
      </not>
    </preConditions>
    <createTable tableName="content_statistics">
      <column name="id" type="BIGINT UNSIGNED" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="content_id" type="VARCHAR(36)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="total_ratings" type="INT" defaultValueNumeric="0"/>
      <column name="average_rating" type="DECIMAL(3,2)" defaultValueNumeric="0.00"/>
      <column name="rating_1_count" type="INT" defaultValueNumeric="0"/>
      <column name="rating_2_count" type="INT" defaultValueNumeric="0"/>
      <column name="rating_3_count" type="INT" defaultValueNumeric="0"/>
      <column name="rating_4_count" type="INT" defaultValueNumeric="0"/>
      <column name="rating_5_count" type="INT" defaultValueNumeric="0"/>
      <column name="total_reviews" type="INT" defaultValueNumeric="0"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <createIndex tableName="content_statistics" indexName="idx_average_rating">
      <column name="average_rating"/>
    </createIndex>
  </changeSet>
  <!--  Create review_helpful table  -->
  <changeSet id="rating-0004-create-review-helpful-table" author="thangVm">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="review_helpful"/>
      </not>
    </preConditions>
    <createTable tableName="review_helpful">
      <column name="id" type="BIGINT UNSIGNED" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="review_id" type="BIGINT UNSIGNED">
        <constraints nullable="false"/>
      </column>
      <column name="user_id" type="VARCHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addUniqueConstraint tableName="review_helpful" columnNames="review_id,user_id" constraintName="uk_review_user"/>
    <addForeignKeyConstraint baseTableName="review_helpful" baseColumnNames="review_id" constraintName="fk_helpful_review" referencedTableName="review" referencedColumnNames="id" onDelete="CASCADE"/>
  </changeSet>
</databaseChangeLog>